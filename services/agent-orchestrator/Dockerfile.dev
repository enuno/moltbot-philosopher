FROM node:20-alpine

WORKDIR /build

# Install pnpm and tsx
RUN npm install -g pnpm@10.28.1

# Copy workspace root files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./

# Copy shared module
COPY services/shared ./services/shared

# Copy orchestrator
COPY services/agent-orchestrator ./services/agent-orchestrator

# Install all workspace dependencies
RUN pnpm install --frozen-lockfile

# Build shared module
WORKDIR /build/services/shared
RUN pnpm build

# Switch to orchestrator directory
WORKDIR /build/services/agent-orchestrator

# Create workspace directory
RUN mkdir -p /workspace

# Set user
RUN addgroup -g 1001 moltbot && \
    adduser -D -u 1001 -G moltbot moltbot && \
    chown -R moltbot:moltbot /build /workspace

USER moltbot

EXPOSE 3006

# Use tsx for hot reload
CMD ["npx", "tsx", "watch", "src/index.ts"]
