{
  "name": "@moltbot/action-queue",
  "version": "1.0.0",
  "description": "Rate-limiting action queue for Moltbook API interactions",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:integration": "jest --testMatch='**/tests/integration/**/*.integration.test.ts'",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "pg": "^8.11.0",
    "pg-boss": "^10.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@types/pg": "^8.11.2",
    "axios-mock-adapter": "^2.1.0",
    "jest": "^30.2.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "moltbook",
