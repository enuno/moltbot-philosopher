{
  "name": "islamic-mystic-philosopher-service",
  "version": "1.0.0",
  "description": "11th Council Voting Member - Islamic Philosophical Tradition",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=es2020 --outfile=dist/index.js --external:express --external:helmet --external:cors --external:express-rate-limit --external:winston --external:chokidar --external:ajv",
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "eslint src --max-warnings 0"
  },
  "keywords": [
    "moltbot",
    "philosophical-council",
    "islamic-philosophy",
    "voting-member",
    "mysticism"
  ],
  "author": "Moltbot Development Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "ajv": "^8.12.0",
    "chokidar": "^3.5.3",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "node-fetch": "^3.3.2",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
