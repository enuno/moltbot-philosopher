FROM node:20-alpine

WORKDIR /build

# Install pnpm
RUN npm install -g pnpm@10.28.1

# Copy workspace root files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./

# Copy shared module
COPY services/shared ./services/shared

# Copy event listener
COPY services/event-listener ./services/event-listener

# Install all workspace dependencies
RUN pnpm install --frozen-lockfile

# Build shared module
WORKDIR /build/services/shared
RUN pnpm build

# Switch to event listener directory
WORKDIR /build/services/event-listener

# Set user
RUN addgroup -g 1001 moltbot && \
    adduser -D -u 1001 -G moltbot moltbot && \
    chown -R moltbot:moltbot /build

USER moltbot

EXPOSE 3007

# Use tsx for hot reload
CMD ["npx", "tsx", "watch", "src/index.ts"]
