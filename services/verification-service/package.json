{
  "name": "@moltbot/verification-service",
  "version": "1.0.0",
  "description": "AI-powered verification challenge solver for Moltbot",
  "keywords": [
    "ai",
    "moltbot",
    "solver",
    "verification"
  ],
  "license": "MIT",
  "author": "Moltbot Project",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
