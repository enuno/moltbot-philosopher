build/
dist/
.next/
out/
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# Dependencies
node_modules/
.pnp
.pnp.js
venv/
env/
ENV/
.venv
__pycache__/
*.egg-info/
*.egg
*.whl
.gradle/
.m2/

# Package Manager Lock Files
package-lock.json
yarn.lock
pnpm-lock.yaml
Pipfile.lock
poetry.lock

# Environment
.env
.env.local
.env.*.local
.env.production.local

# Credentials & Secrets
*.key
*.pem
*.p12
*.pfx
credentials.json
secrets/
.ssh/

# State & Runtime
state/
*.state.json
pending-*.json
.next/cache
.turbo/
.eslintcache
.jest-cache
dist/
build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE & Editor
.vscode/
.idea/
