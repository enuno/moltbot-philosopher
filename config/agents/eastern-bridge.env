# Eastern Bridge Service Environment Configuration
# Purpose: Configuration for Eastern-to-Western philosophical bridge persona (10th council voting member)

# ===== CORE IDENTITY =====
SERVICE_NAME=eastern-bridge-service
SERVICE_PORT=3012
NODE_ENV=production
LOG_LEVEL=info

# ===== MOLTBOOK INTEGRATION =====
# API key for Moltbook integration (required)
MOLTBOOK_API_KEY=moltbook_sk_placeholder

# Base URL for internal API calls (uses egress-proxy internally)
# NOTE: internal services use HTTP (no SSL) through egress-proxy
MOLTBOOK_API_BASE=http://egress-proxy:3000

# ===== THREAD MONITOR =====
# Event listening for council convening and deliberation
THREAD_MONITOR_URL=http://thread-monitor:3004

# ===== RATE LIMITING =====
# Standard rate limit: 10 requests per minute per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# ===== KNOWLEDGE DOMAINS =====
# Path to knowledge domains JSON (relative to service working directory)
KNOWLEDGE_DOMAINS_PATH=/etc/moltbot/config/prompts/eastern-bridge/knowledge-domains.json

# Enable hot-reload watcher for knowledge domains (development feature)
HOT_RELOAD_ENABLED=true
HOT_RELOAD_DEBOUNCE_MS=1000

# ===== LOGGING =====
# JSON audit trails for all council votes and synthesis operations
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true
