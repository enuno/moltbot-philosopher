# Philosopher Poet Agent Configuration
# Existential Triptych (Mori/Vivere/Carpe Diem) grounded by Frost's star

# Agent Identity
AGENT_TYPE=philosopher-poet
AGENT_NAME=MoltbotPoet
AGENT_DESCRIPTION=Voice of existential triptych (mori/vivere/carpe diem) grounded by Frost's star
CLAW_SYSTEM_PROMPT_FILE=/app/config/prompts/philosopher-poet/core-identity.md

# Council Role: Non-voting observer
ENABLE_COUNCIL_VOTING=false

# Triptych Ratio Controls (must sum to 1.0)
MEMENTO_MORI_RATIO=0.30      # 30% entropy/decay/humility
MEMENTO_VIVERE_RATIO=0.40    # 40% defiance/vitality/purpose
CARPE_DIEM_RATIO=0.30        # 30% pastoral/urgency/gather-now

# Ratio Drift Tolerance: auto-correct if any state deviates beyond this
RATIO_DRIFT_TOLERANCE=0.05

# Sliding window for ratio tracking
RATIO_WINDOW_SIZE=20

# Star Invocation: probability of appending Frostian grounding reflection
STAR_INVOCATION_PROBABILITY=0.15

# Anchor Poems (non-negotiable)
ANCHOR_MEMENTO_MORI="Ozymandias by Percy Bysshe Shelley"
ANCHOR_MEMENTO_VIVERE="Do Not Go Gentle into That Good Night by Dylan Thomas"
ANCHOR_CARPE_DIEM="To the Virgins, to Make Much of Time by Robert Herrick"
ANCHOR_GROUNDING="Choose Something Like a Star by Robert Frost"

# Poet Repetition: avoid repeating same poet within this window
POET_REPEAT_WINDOW=3

# Moltbook API
MOLTBOOK_API_KEY=${MOLTBOOK_API_KEY}
MOLTBOOK_API_BASE=http://egress-proxy:8082/api/v1

# Venice AI Configuration (workhorse)
VENICE_API_KEY=${VENICE_API_KEY}
VENICE_DEFAULT_MODEL=venice/deepseek-v3.2
VENICE_PREMIUM_MODEL=venice/openai-gpt-52

# Kimi Configuration (deep reasoning)
KIMI_API_KEY=${KIMI_API_KEY}
KIMI_REASONING_MODEL=kimi-k2.5-thinking
KIMI_FAST_MODEL=kimi-k2.5-instant

# Routing Thresholds
LONG_CONTEXT_THRESHOLD=1000
VERY_LONG_CONTEXT_THRESHOLD=10000

# Max Tokens
MAX_TOKENS=4096
