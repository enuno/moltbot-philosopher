# Eastern-to-Western Philosophical Bridge Agent Configuration
# Synthesizes Eastern philosophy (Hinduism, Buddhism, Taoism, Confucianism,
# Jainism, Shinto) for Western audiences via Jungian archetypal psychology

# Agent Identity
AGENT_TYPE=eastern-western-bridge
AGENT_NAME=MoltbotEasternBridge
AGENT_DESCRIPTION=Cross-cultural philosophical translator specializing in Eastern-to-Western synthesis
CLAW_SYSTEM_PROMPT_FILE=/app/config/prompts/eastern-western-bridge/system-prompt.txt
MAX_TOKENS=16384

# Moltbook API
MOLTBOOK_API_KEY=${MOLTBOOK_API_KEY_EASTERN_BRIDGE}
MOLTBOOK_API_BASE=http://egress-proxy:8082/api/v1

# Venice AI Configuration (workhorse)
VENICE_API_KEY=${VENICE_API_KEY}
VENICE_DEFAULT_MODEL=venice/deepseek-v3.2
VENICE_PREMIUM_MODEL=venice/openai-gpt-52

# Kimi Configuration (deep reasoning)
KIMI_API_KEY=${KIMI_API_KEY}
KIMI_REASONING_MODEL=kimi-k2.5-thinking
KIMI_FAST_MODEL=kimi-k2.5-instant

# Routing Thresholds
LONG_CONTEXT_THRESHOLD=1000
VERY_LONG_CONTEXT_THRESHOLD=10000

# Bridge-specific feature flags
ENABLE_COUNCIL_VOTING=true
BRIDGE_STYLE=literary_scholarly
SYNTHESIS_MODE=parallel_traditions
JUNGIAN_INTEGRATION=true

# Knowledge domain config paths
KNOWLEDGE_DOMAINS_PATH=/app/config/prompts/eastern-western-bridge/knowledge-domains.json
TRANSLATION_MODES_PATH=/app/config/prompts/eastern-western-bridge/translation-modes.json

# Thread Monitor Service
THREAD_MONITOR_URL=http://thread-monitor:3004
