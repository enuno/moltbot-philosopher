# Islamic Mystic Philosopher Service Configuration
# Port: 3013

# Service Identification
SERVICE_NAME=islamic-mystic-philosopher
SERVICE_PORT=3013
SERVICE_VERSION=1.0.0
AGENT_TYPE=islamic_philosopher
ROLE_PRIMARY=ethics_core
ETHICS_CORE_MEMBER=true

# API Configuration
MOLTBOOK_API_KEY=${MOLTBOOK_API_KEY}
MOLTBOOK_API_TIMEOUT_MS=5000
MOLTBOOK_ENDPOINT=https://www.moltbook.com/api/v1

# Knowledge Configuration
KNOWLEDGE_DOMAINS_PATH=/app/config/prompts/islamic-mystic-philosopher/knowledge-domains.json
KNOWLEDGE_HOT_RELOAD=true
KNOWLEDGE_HOT_RELOAD_DEBOUNCE_MS=1000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_KEY_PREFIX=islamic-philosopher

# Circuit Breaker (for API timeout handling)
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000

# Philosopher Selection Strategy
SELECTION_MODE=hybrid

# Logging
LOG_LEVEL=info
AUDIT_LOG_ENABLED=true
STRUCTURED_LOG_FORMAT=json

# Debate Strategies (when voting against each council member's position)
DEBATE_VS_CLASSICAL=Emphasize historical precedent and continuity with Islamic intellectual tradition
DEBATE_VS_EXISTENTIALIST=Ground existential choice in divine will (qadar) and human responsibility (taklif)
DEBATE_VS_TRANSCENDENTALIST=Align countercultural critique with ascetic traditions and rejection of material attachment (zuhd)
DEBATE_VS_EASTERN=Note complementary non-dualism (wahdat al-wujud) and mystical methods (dhikr, muraqaba)
DEBATE_VS_CYBERPUNK=Invoke Islamic principles of human dignity, prohibition of deception (ghish), and governance by law (shari'ah)
DEBATE_VS_BEAT=Connect spiritual freedom to Islamic ascetic rejection of worldly concerns
DEBATE_VS_SATIRIST=Emphasize Islamic critique of hypocrisy and moral accountability (taklif)
DEBATE_VS_SCIENTIST=Ground scientific reasoning within divine causation framework
DEBATE_VS_EASTERN_BRIDGE=Complement Western-oriented synthesis with authentic Islamic sources and epistemology

# Feature Flags
ENABLE_HOTFIX_LOGGING=true
ENABLE_PHILOSOPHER_METADATA=true
