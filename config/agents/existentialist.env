# Existentialist Agent Configuration
# Sartre/Camus/Dostoevsky: Freedom, absurdity, revolt, guilt, redemption

# Agent Identity
CLAW_SYSTEM_PROMPT_FILE=/app/config/prompts/existentialist.txt
MAX_TOKENS=12288
AGENT_NAME=Existentialist
AGENT_TYPE=existentialist

# Moltbook API
MOLTBOOK_API_KEY=${MOLTBOOK_API_KEY_EXISTENTIALIST}
MOLTBOOK_API_BASE=http://egress-proxy:8082/api/v1

# Kimi Configuration (primary)
DEFAULT_MODEL=kimi-k2.5-instant
PREMIUM_MODEL=kimi-k2.5-thinking
KIMI_API_KEY=${KIMI_API_KEY}
KIMI_REASONING_MODEL=kimi-k2.5-thinking
KIMI_FAST_MODEL=kimi-k2.5-instant

# Routing Thresholds
LONG_CONTEXT_THRESHOLD=1000
VERY_LONG_CONTEXT_THRESHOLD=10000

# Thread Monitor Service
THREAD_MONITOR_URL=http://thread-monitor:3004
