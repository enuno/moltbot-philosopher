# MoltbotPhilosopher v2.6 - Environment Configuration
# Copy this file to .env and fill in your actual values
# REQUIRED variables must be set or the system will not function
# OPTIONAL variables have sensible defaults and can be omitted

# ================================================================================
# REQUIRED - Core API Credentials
# ================================================================================

# Moltbook API Key (REQUIRED)
# Get from: https://www.moltbook.com
# Used for: All Moltbook social network integration
MOLTBOOK_API_KEY=moltbook_sk_your_key_here

# ================================================================================
# OPTIONAL - AI Provider Configuration
# ================================================================================
# At least ONE of Venice or Kimi should be configured for AI content generation
# If neither is configured, the system falls back to template-based posts

# Venice AI API Key (OPTIONAL)
# Get from: https://venice.ai
# Used for: Content generation, model routing
# Default: Empty (falls back to templates if not set)
VENICE_API_KEY=venice_sk_your_key_here

# Kimi API Key (OPTIONAL)
# Get from: https://platform.moonshot.cn
# Used for: Deep reasoning, philosophical analysis
# Default: Empty (falls back to Venice if not set)
KIMI_API_KEY=kimi_sk_your_key_here

# ================================================================================
# OPTIONAL - AI Service URLs
# ================================================================================
# These are Docker Compose service URLs - only change if running custom setup

# AI Content Generator Service URL (OPTIONAL)
# Default: http://ai-generator:3000
AI_GENERATOR_SERVICE_URL=http://ai-generator:3000

# Venice API Proxy URL (OPTIONAL)
# Default: http://venice-proxy:8080/v1/chat/completions
VENICE_API_URL=http://venice-proxy:8080/v1/chat/completions

# Kimi API Proxy URL (OPTIONAL)
# Default: http://kimi-proxy:8081/v1/chat/completions
KIMI_API_URL=http://kimi-proxy:8081/v1/chat/completions

# Model Router Service URL (OPTIONAL)
# Default: http://model-router:3000
MODEL_ROUTER_URL=http://model-router:3000

# ================================================================================
# OPTIONAL - AI Model Selection
# ================================================================================
# These specify which models to use for AI generation

# Venice Default Model (OPTIONAL)
# Options: llama-3.3-70b, openai-gpt-52, deepseek-v3.2
# Default: llama-3.3-70b
VENICE_MODEL=llama-3.3-70b

# Kimi Default Model (OPTIONAL)
# Options: kimi-k2.5-thinking, kimi-k2-0711-preview
# Default: kimi-k2.5-thinking
KIMI_MODEL=kimi-k2.5-thinking

# ================================================================================
# OPTIONAL - Agent Configuration
# ================================================================================

# Agent Type (OPTIONAL)
# Which philosopher persona to use for the main agent
# Options: classical, existentialist, transcendentalist, joyce, enlightenment, beat, cyberpunk, satirist, scientist
# Default: classical
AGENT_TYPE=classical

# Agent Name (OPTIONAL)
# Display name for the agent on Moltbook
# Default: MoltbotPhilosopher
AGENT_NAME=MoltbotPhilosopher

# Agent Description (OPTIONAL)
# Profile description for Moltbook
# Default: A philosophical AI agent exploring wisdom through Socratic dialogue
AGENT_DESCRIPTION=A philosophical AI agent exploring wisdom through Socratic dialogue

# Moltbot State Directory (OPTIONAL)
# Where persistent state files are stored
# Default: /workspace/classical
MOLTBOT_STATE_DIR=/workspace/classical

# ================================================================================
# OPTIONAL - Heartbeat & Scheduling
# ================================================================================
# Controls how often the agent checks for activity

# Heartbeat Interval (OPTIONAL)
# Seconds between heartbeat checks (DMs, mentions, feed, new users)
# Default: 14400 (4 hours)
HEARTBEAT_INTERVAL=14400

# Enable Auto-Welcome (OPTIONAL)
# Automatically welcome new community members
# Options: true, false
# Default: true
ENABLE_AUTO_WELCOME=true

# Enable Auto-Reply to Mentions (OPTIONAL)
# Automatically reply to mentions (requires human approval first)
# Options: true, false
# Default: false
ENABLE_MENTION_AUTO_REPLY=false

# Enable Daily Polemic (OPTIONAL)
# Post daily philosophical content
# Options: true, false
# Default: false
ENABLE_DAILY_POLEMIC=false

# Daily Polemic Hour UTC (OPTIONAL)
# What hour (0-23) to post daily content
# Default: 9 (9 AM UTC)
POLEMIC_HOUR_UTC=9

# ================================================================================
# OPTIONAL - Memory & Noosphere
# ================================================================================
# Controls the memory consolidation and vector search system

# Noosphere Directory (OPTIONAL)
# Where the living memory system stores heuristics and vectors
# Default: /workspace/classical/noosphere
NOOSPHERE_DIR=/workspace/classical/noosphere

# Vector Index Frequency (OPTIONAL)
# How often to re-index heuristics for semantic search (days)
# Default: 3
VECTOR_INDEX_FREQUENCY_DAYS=3

# Memory Consolidation Batch Size (OPTIONAL)
# How many daily notes to process per consolidation
# Default: 100
CONSOLIDATION_BATCH_SIZE=100

# ================================================================================
# OPTIONAL - Governance & Council
# ================================================================================
# Controls the Ethics-Convergence Council functionality

# Council Consensus Threshold (OPTIONAL)
# Number of agents required to agree for binding decisions
# Default: 4 (out of 6)
COUNCIL_CONSENSUS_THRESHOLD=4

# Council Deliberation Interval (OPTIONAL)
# Days between full Council iterations
# Default: 5
COUNCIL_ITERATION_DAYS=5

# ================================================================================
# OPTIONAL - Mem0 API Integration
# ================================================================================
# Mem0 provides agentic memory for personalized AI interactions

# Mem0 API Key (OPTIONAL)
# Get from: https://mem0.ai
# Used for: Agent memory persistence, user preference learning
# Default: Empty (Mem0 features disabled, uses Noosphere instead)
MEM0_API_KEY=

# Mem0 API URL (OPTIONAL)
# Mem0 API endpoint for memory operations
# Default: https://api.mem0.ai/v1
MEM0_API_URL=https://api.mem0.ai/v1

# Mem0 Org ID (OPTIONAL)
# Organization ID for Mem0 (found in Mem0 dashboard)
# Default: Empty (uses default org)
MEM0_ORG_ID=

# Mem0 User ID (OPTIONAL)
# User ID for memory segregation (can be agent name or ID)
# Default: moltbot-philosopher
MEM0_USER_ID=moltbot-philosopher

# Enable Mem0 Memory Store (OPTIONAL)
# Use Mem0 for agent memory in addition to Noosphere
# Options: true, false
# Default: false (uses Noosphere as primary)
ENABLE_MEM0_STORE=false

# ================================================================================
# OPTIONAL - Notifications (NTFY)
# ================================================================================
# Real-time alerting system for agent actions

# NTFY URL (OPTIONAL)
# ntfy.sh push notification service endpoint
# Example: https://ntfy.sh or self-hosted: https://ntfy.example.com
# Default: Empty (notifications disabled)
NTFY_URL=

# NTFY API Key (OPTIONAL)
# Authentication token for ntfy service
# Default: Empty
NTFY_API_KEY=

# NTFY Topic (OPTIONAL)
# Which topic to publish notifications to
# Default: moltbot-philosopher
NTFY_TOPIC=moltbot-philosopher

# ================================================================================
# OPTIONAL - Logging & Debugging
# ================================================================================

# Log Level (OPTIONAL)
# Options: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Log Format (OPTIONAL)
# Options: json, text
# Default: json
LOG_FORMAT=json

# Enable Debug Logging (OPTIONAL)
# Extra verbose output for troubleshooting
# Options: true, false
# Default: false
DEBUG=false

# ================================================================================
# OPTIONAL - Feature Flags
# ================================================================================
# Enable/disable specific features

# Enable AI Generation (OPTIONAL)
# Use AI providers for content generation
# Default: true
ENABLE_AI_GENERATION=true

# Enable Mention Detection (OPTIONAL)
# Monitor and suggest replies to mentions
# Default: true
ENABLE_MENTION_DETECTION=true

# Enable Welcome New Moltys (OPTIONAL)
# Automatically detect and welcome new community members
# Default: true
ENABLE_WELCOME_NEW_MOLTYS=true

# Enable Following with Criteria (OPTIONAL)
# Follow users only if they meet quality criteria
# Default: true
ENABLE_FOLLOWING_CRITERIA=true

# Enable Thread Continuation (OPTIONAL)
# Keep philosophical threads alive with STP synthesis
# Default: true
ENABLE_THREAD_CONTINUATION=true

# Enable Semantic Search (OPTIONAL)
# Use vector embeddings for heuristic retrieval
# Default: true
ENABLE_SEMANTIC_SEARCH=true

# ================================================================================
# OPTIONAL - Rate Limiting & Throttling
# ============================================================= ====================

# Post Rate Limit (OPTIONAL)
# Maximum posts per day
# Default: 2
MAX_POSTS_PER_DAY=2

# Comment Rate Limit (OPTIONAL)
# Maximum comments per day
# Default: 50
MAX_COMMENTS_PER_DAY=50

# Comment Rate Per Post (OPTIONAL)
# Maximum seconds between comments on same post
# Default: 20
COMMENT_RATE_SECONDS=20

# Follow Rate Limit (OPTIONAL)
# Maximum users to follow per day
# Default: 10
MAX_FOLLOW_PER_DAY=10

# ================================================================================
# OPTIONAL - Docker/Container Settings
# ================================================================================

# Container User (OPTIONAL)
# UID:GID for file permissions (critical for state files)
# Default: 1001:1001
CONTAINER_UID=1001

# Workspace Volume Mount (OPTIONAL)
# Path to workspace directory on host
# Default: ./workspace
WORKSPACE_PATH=./workspace

# ================================================================================
# SUMMARY OF REQUIRED vs OPTIONAL
# ================================================================================
#
# REQUIRED (must be set):
#   - MOLTBOOK_API_KEY
#
# OPTIONAL BUT RECOMMENDED (should configure for full functionality):
#   - VENICE_API_KEY or KIMI_API_KEY (at least one for AI generation)
#   - NTFY_URL + NTFY_API_KEY (for real-time notifications)
#
# OPTIONAL WITH SENSIBLE DEFAULTS:
#   - All other variables (safe to leave as-is)
#
# MEMORY SYSTEMS:
#   - Noosphere: Built-in 3-layer memory (always enabled, default)
#   - Mem0: Optional agentic memory service (requires MEM0_API_KEY)
#   - Both can work together (Noosphere primary, Mem0 supplemental)
#
# Notes:
# - If Venice and Kimi keys are both missing, the system falls back to templates
# - If NTFY is not configured, notifications are silently disabled
# - If MEM0_API_KEY is not set, Mem0 features are disabled (Noosphere is primary)
# - Docker Compose service URLs should not need changing in standard setup
# - Workspace permissions (CONTAINER_UID) are critical if rebuilding
#
# For help, see: README.md and AGENTS.md
