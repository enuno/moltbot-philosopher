# MoltbotPhilosopher v2.6 - Environment Configuration
# Copy this file to .env and fill in your actual values
# REQUIRED variables must be set or the system will not function
# OPTIONAL variables have sensible defaults and can be omitted

# ================================================================================
# REQUIRED - Core API Credentials
# ================================================================================

# Moltbook API Key (REQUIRED)
# Get from: https://www.moltbook.com
# Used for: All Moltbook social network integration
MOLTBOOK_API_KEY=moltbook_sk_your_key_here

# Per-Agent API Keys (OPTIONAL)
# By default, all agents use the main MOLTBOOK_API_KEY
# Set these only if you want different Moltbook accounts for different agents
# Default: ${MOLTBOOK_API_KEY} (uses main key)
MOLTBOOK_API_KEY_TRANSCENDENTALIST=${MOLTBOOK_API_KEY}
MOLTBOOK_API_KEY_EXISTENTIALIST=${MOLTBOOK_API_KEY}
MOLTBOOK_API_KEY_JOYCE=${MOLTBOOK_API_KEY}
MOLTBOOK_API_KEY_ENLIGHTENMENT=${MOLTBOOK_API_KEY}
MOLTBOOK_API_KEY_BEAT=${MOLTBOOK_API_KEY}

# ================================================================================
# OPTIONAL - AI Provider Configuration
# ================================================================================
# At least ONE of Venice or Kimi should be configured for AI content generation
# If neither is configured, the system falls back to template-based posts

# Venice AI API Key (OPTIONAL)
# Get from: https://venice.ai
# Used for: Content generation, model routing
# Default: Empty (falls back to templates if not set)
VENICE_API_KEY=venice_sk_your_key_here

# Kimi API Key (OPTIONAL)
# Get from: https://platform.moonshot.cn
# Used for: Deep reasoning, philosophical analysis
# Default: Empty (falls back to Venice if not set)
KIMI_API_KEY=kimi_sk_your_key_here

# ================================================================================
# OPTIONAL - AI Service URLs
# ================================================================================
# These are Docker Compose service URLs - only change if running custom setup

# AI Content Generator Service URL (OPTIONAL)
# Default: http://ai-generator:3000
AI_GENERATOR_SERVICE_URL=http://ai-generator:3000

# Venice API Proxy URL (OPTIONAL)
# Default: http://venice-proxy:8080/v1/chat/completions
VENICE_API_URL=http://venice-proxy:8080/v1/chat/completions

# Kimi API Proxy URL (OPTIONAL)
# Default: http://kimi-proxy:8081/v1/chat/completions
KIMI_API_URL=http://kimi-proxy:8081/v1/chat/completions

# Model Router Service URL (OPTIONAL)
# Default: http://model-router:3000
MODEL_ROUTER_URL=http://model-router:3000

# ================================================================================
# OPTIONAL - AI Model Selection
# ================================================================================
# These specify which models to use for AI generation

# Venice Default Model (OPTIONAL)
# Options: llama-3.3-70b, openai-gpt-52, deepseek-v3.2
# Default: llama-3.3-70b
VENICE_MODEL=llama-3.3-70b

# Kimi Default Model (OPTIONAL)
# Options: kimi-k2.5-thinking, kimi-k2-0711-preview
# Default: kimi-k2.5-thinking
KIMI_MODEL=kimi-k2.5-thinking

# ================================================================================
# OPTIONAL - Agent Configuration
# ================================================================================

# Agent Type (OPTIONAL)
# Which philosopher persona to use for the main agent
# Options: classical, existentialist, transcendentalist, joyce, enlightenment, beat, cyberpunk, satirist, scientist
# Default: classical
AGENT_TYPE=classical

# Agent Name (OPTIONAL)
# Display name for the agent on Moltbook
# Default: MoltbotPhilosopher
AGENT_NAME=MoltbotPhilosopher

# Agent Description (OPTIONAL)
# Profile description for Moltbook
# Default: A philosophical AI agent exploring wisdom through Socratic dialogue
AGENT_DESCRIPTION=A philosophical AI agent exploring wisdom through Socratic dialogue

# Moltbot State Directory (OPTIONAL)
# Where persistent state files are stored
# Default: /workspace/classical
MOLTBOT_STATE_DIR=/workspace/classical

# ================================================================================
# OPTIONAL - Heartbeat & Scheduling
# ================================================================================
# Controls how often the agent checks for activity

# Heartbeat Interval (OPTIONAL)
# Seconds between heartbeat checks (DMs, mentions, feed, new users)
# Default: 14400 (4 hours)
HEARTBEAT_INTERVAL=14400

# Enable Auto-Welcome (OPTIONAL)
# Automatically welcome new community members
# Options: true, false
# Default: true
ENABLE_AUTO_WELCOME=true

# Enable Auto-Reply to Mentions (OPTIONAL)
# Automatically reply to mentions (requires human approval first)
# Options: true, false
# Default: false
ENABLE_MENTION_AUTO_REPLY=false

# Enable Daily Polemic (OPTIONAL)
# Post daily philosophical content
# Options: true, false
# Default: false
ENABLE_DAILY_POLEMIC=false

# Daily Polemic Hour UTC (OPTIONAL)
# What hour (0-23) to post daily content
# Default: 9 (9 AM UTC)
POLEMIC_HOUR_UTC=9

# Enable DM Monitor (OPTIONAL)
# Automatically check DMs on every heartbeat cycle and send NTFY notifications.
# When a pending chat request is detected the human operator receives an NTFY
# push notification so they can approve/reject/block.
# WARNING: DM messages may be included in NTFY notifications. Only enable if
# your NTFY_URL points to a trusted/self-hosted instance.
# Options: true, false
# Default: false (explicitly enable if you understand the privacy implications)
ENABLE_DM_MONITOR=false

# Include full DM message content in NTFY notifications (OPTIONAL)
# By default, DM notifications are redacted (message truncated, newlines removed).
# Set to true to include full message content, but only if using a trusted NTFY instance.
# Options: true, false
# Default: false
DM_MONITOR_INCLUDE_FULL_CONTENT=false

# Egress Proxy for Moltbook API calls (OPTIONAL)
# Routes DM monitor API requests through the intelligent egress proxy service
# for transparent PoW challenge handling and request forwarding.
# If proxy is unavailable, falls back to direct HTTPS.
# Format: http://<service>:<port> (no trailing slash)
# Default: http://egress-proxy:8082
EGRESS_PROXY=http://egress-proxy:8082

# ================================================================================
# OPTIONAL - Memory & Noosphere
# ================================================================================
# Controls the memory consolidation and vector search system

# Noosphere Directory (OPTIONAL)
# Where the living memory system stores heuristics and vectors
# Default: /workspace/classical/noosphere
NOOSPHERE_DIR=/workspace/classical/noosphere

# Vector Index Frequency (OPTIONAL)
# How often to re-index heuristics for semantic search (days)
# Default: 3
VECTOR_INDEX_FREQUENCY_DAYS=3

# Memory Consolidation Batch Size (OPTIONAL)
# How many daily notes to process per consolidation
# Default: 100
CONSOLIDATION_BATCH_SIZE=100

# ================================================================================
# OPTIONAL - Governance & Council
# ================================================================================
# Controls the Ethics-Convergence Council functionality

# Council Consensus Threshold (OPTIONAL)
# Number of agents required to agree for binding decisions
# Default: 4 (out of 6)
COUNCIL_CONSENSUS_THRESHOLD=4

# Council Deliberation Interval (OPTIONAL)
# Days between full Council iterations
# Default: 5
COUNCIL_ITERATION_DAYS=5

# ================================================================================
# OPTIONAL - Mem0 API Integration
# ================================================================================
# Mem0 provides agentic memory for personalized AI interactions

# Mem0 API Key (OPTIONAL)
# Get from: https://mem0.ai
# Used for: Agent memory persistence, user preference learning
# Default: Empty (Mem0 features disabled, uses Noosphere instead)
MEM0_API_KEY=

# Mem0 API URL (OPTIONAL)
# Mem0 API endpoint for memory operations
# Default: https://api.mem0.ai/v1
MEM0_API_URL=https://api.mem0.ai/v1

# Mem0 Org ID (OPTIONAL)
# Organization ID for Mem0 (found in Mem0 dashboard)
# Default: Empty (uses default org)
MEM0_ORG_ID=

# Mem0 User ID (OPTIONAL)
# User ID for memory segregation (can be agent name or ID)
# Default: moltbot-philosopher
MEM0_USER_ID=moltbot-philosopher

# Mem0 Project ID (OPTIONAL)
# Project ID for Living Noosphere (get from: python3 workspace/classical/noosphere/mem0-living-noosphere.py --action create-project)
# Default: Empty (no project association)
MEM0_PROJECT_ID=

# Enable Mem0 Memory Store (OPTIONAL)
# Use Mem0 for agent memory in addition to Noosphere
# Options: true, false
# Default: false (uses Noosphere as primary)
ENABLE_MEM0_STORE=false

# ================================================================================
# OPTIONAL - Moltstack Integration
# ================================================================================
# Long-form publishing platform for philosophical essays

# Moltstack API Key (OPTIONAL)
# Get from: https://moltstack.net/settings/api
# Used for: Publishing long-form essays to The Divided Line
# Default: Empty (Moltstack features disabled)
MOLTSTACK_API_KEY=

# Moltstack Publication Slug (OPTIONAL)
# Your publication identifier on Moltstack
# Default: noesis
MOLTSTACK_PUBLICATION_SLUG=noesis

# Moltstack Post Interval (OPTIONAL)
# Minimum seconds between article publishes (rate limiting)
# Default: 604800 (7 days / 1 week)
MOLTSTACK_POST_INTERVAL=604800

# Moltstack API URL (OPTIONAL)
# API endpoint for Moltstack service
# Default: https://moltstack.net/api
MOLTSTACK_API_URL=https://moltstack.net/api

# ================================================================================
# OPTIONAL - Notifications (NTFY)
# ================================================================================
# Real-time alerting system for agent actions

# NTFY URL (OPTIONAL)
# ntfy.sh push notification service endpoint
# Example: https://ntfy.sh or self-hosted: https://ntfy.example.com
# Default: Empty (notifications disabled)
NTFY_URL=

# NTFY API Key (OPTIONAL)
# Authentication token for ntfy service
# Default: Empty
NTFY_API_KEY=

# NTFY Topic (OPTIONAL)
# Which topic to publish notifications to
# Default: moltbot-philosopher
NTFY_TOPIC=moltbot-philosopher

# ================================================================================
# OPTIONAL - Logging & Debugging
# ================================================================================

# Log Level (OPTIONAL)
# Options: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Log Format (OPTIONAL)
# Options: json, text
# Default: json
LOG_FORMAT=json

# Enable Debug Logging (OPTIONAL)
# Extra verbose output for troubleshooting
# Options: true, false
# Default: false
DEBUG=false

# ================================================================================
# OPTIONAL - Feature Flags
# ================================================================================
# Enable/disable specific features

# Enable AI Generation (OPTIONAL)
# Use AI providers for content generation
# Default: true
ENABLE_AI_GENERATION=true

# Enable Mention Detection (OPTIONAL)
# Monitor and suggest replies to mentions
# Default: true
ENABLE_MENTION_DETECTION=true

# Enable Welcome New Moltys (OPTIONAL)
# Automatically detect and welcome new community members
# Default: true
ENABLE_WELCOME_NEW_MOLTYS=true

# Enable Following with Criteria (OPTIONAL)
# Follow users only if they meet quality criteria
# Default: true
ENABLE_FOLLOWING_CRITERIA=true

# Enable Thread Continuation (OPTIONAL)
# Keep philosophical threads alive with STP synthesis
# Default: true
ENABLE_THREAD_CONTINUATION=true

# Enable Semantic Search (OPTIONAL)
# Use vector embeddings for heuristic retrieval
# Default: true
ENABLE_SEMANTIC_SEARCH=true

# ================================================================================
# OPTIONAL - P4.1 Hybrid Search Scoring Configuration
# ================================================================================
# Fine-tune the hybrid search ranking system for relevance, freshness, and author credibility

# Scoring Weights
# Historical Author Quality Weight (OPTIONAL)
# How much to weight long-term author quality scores (0-1 scale)
# Higher = more weight on consistent quality, lower = less conservative
# Default: 0.5
SCORING_HISTORICAL_WEIGHT=0.5

# Recent Author Engagement Weight (OPTIONAL)
# How much to weight recent engagement signals (upvotes, comments)
# Higher = more responsive to recent activity, lower = more stable
# Default: 0.25
SCORING_RECENT_WEIGHT=0.25

# Scoring Exponents (multiplicative scaling)
# Recency Exponent (OPTIONAL)
# Controls penalty for post age: higher exponent = steeper decay
# Range: 0.5 (gentle decay), 1.0 (standard), 2.0 (aggressive)
# Default: 1.0
SCORING_RECENCY_EXPONENT=1.0

# Reputation Exponent (OPTIONAL)
# Controls influence of author credibility: higher exponent = stronger preference for reputable authors
# Range: 0.5 (gentle), 1.0 (standard), 2.0 (aggressive)
# Default: 1.0
SCORING_REPUTATION_EXPONENT=1.0

# Recency Half-Life (OPTIONAL)
# Number of days for post to decay to 50% score
# Higher = older posts remain relevant longer
# Default: 7 (posts decay to 50% after 7 days)
SCORING_RECENCY_HALF_LIFE=7

# Multipliers
# Follow Boost Multiplier (OPTIONAL)
# Bonus multiplier when agent follows the author
# Range: 1.0 (no boost), 1.5 (50% boost), 2.0 (100% boost)
# Default: 1.25 (25% boost for followed authors)
SCORING_FOLLOW_BOOST=1.25

# Reputation Score Clamp Bounds (OPTIONAL)
# Minimum and maximum multipliers for author reputation
# Prevents extreme values from dominating ranking
# SCORING_REP_MIN: Lower bound (prevents very low scores from authors with poor history)
# SCORING_REP_MAX: Upper bound (prevents very high scores from skewing results)
# Default: 0.5-1.5 (reputation multiplier between 0.5x and 1.5x)
SCORING_REP_MIN=0.5
SCORING_REP_MAX=1.5

# Feature Flags - Enable/Disable Scoring Factors (OPTIONAL)
# Toggle individual scoring factors on/off for A/B testing
# Set to "false" to disable; any other value (including empty) enables

# Enable Recency Decay (OPTIONAL)
# If false, all posts weighted equally regardless of age
# Default: true (recency is enabled)
ENABLE_RECENCY=true

# Enable Reputation Multiplier (OPTIONAL)
# If false, all authors weighted equally regardless of quality
# Default: true (reputation is enabled)
ENABLE_REPUTATION=true

# Enable Follow Boost (OPTIONAL)
# If false, followed authors get no ranking boost
# Default: true (follow boost is enabled)
ENABLE_FOLLOW_BOOST=true

# Enable Debug Output (OPTIONAL)
# If true, include intermediate scoring details in search results
# Useful for troubleshooting and understanding ranking decisions
# Default: false (disabled by default for performance)
ENABLE_DEBUG=false

# ================================================================================
# OPTIONAL - Rate Limiting & Throttling
# ============================================================= ====================

# Post Rate Limit (OPTIONAL)
# Maximum posts per day
# Default: 2
MAX_POSTS_PER_DAY=2

# Comment Rate Limit (OPTIONAL)
# Maximum comments per day
# Default: 50
MAX_COMMENTS_PER_DAY=50

# Comment Rate Per Post (OPTIONAL)
# Maximum seconds between comments on same post
# Default: 20
COMMENT_RATE_SECONDS=20

# Follow Rate Limit (OPTIONAL)
# Maximum users to follow per day
# Default: 10
MAX_FOLLOW_PER_DAY=10

# ================================================================================
# OPTIONAL - PostgreSQL Configuration
# ================================================================================
# Required for Noosphere service and action-queue persistence
# These values must match across postgres, noosphere-service, and action-queue

# PostgreSQL Administrator User (OPTIONAL)
# Default: noosphere_admin
POSTGRES_USER=noosphere_admin

# PostgreSQL Administrator Password (OPTIONAL)
# SECURITY WARNING: Change this in production!
# Default: changeme_noosphere_2026
POSTGRES_PASSWORD=changeme_noosphere_2026

# PostgreSQL Host (OPTIONAL)
# In Docker Compose: service name (postgres)
# In external setup: IP address or hostname
# Default: postgres
POSTGRES_HOST=postgres

# PostgreSQL Port (OPTIONAL)
# Standard PostgreSQL port
# Default: 5432
POSTGRES_PORT=5432

# PostgreSQL Database Name - Noosphere (OPTIONAL)
# Default: noosphere
POSTGRES_DB=noosphere

# PostgreSQL Database Name - Action Queue (OPTIONAL)
# Default: action_queue
POSTGRES_ACTION_QUEUE_DB=action_queue

# PostgreSQL Connection String - Noosphere (OPTIONAL)
# Format: postgresql://user:password@host:port/database
# This is auto-generated from components above if not specified
# DATABASE_URL=postgresql://noosphere_admin:changeme_noosphere_2026@postgres:5432/noosphere

# PostgreSQL Connection String - Action Queue (OPTIONAL)
# Format: postgresql://user:password@host:port/database
# ACTION_QUEUE_DATABASE_URL=postgresql://noosphere_admin:changeme_noosphere_2026@postgres:5432/action_queue

# ================================================================================
# OPTIONAL - Action Queue Service Configuration
# ================================================================================
# pg-boss queue processor configuration for Moltbook action execution

# Action Queue Service Port (OPTIONAL)
# HTTP port for action-queue service API
# Default: 3008
ACTION_QUEUE_PORT=3008

# Queue Processing Interval (OPTIONAL)
# How often to check and process queued actions (seconds)
# Recommended: 5-30 seconds (lower = more responsive, higher = less CPU)
# Default: 5
QUEUE_PROCESSING_INTERVAL=5

# Scheduled Jobs Check Interval (OPTIONAL)
# How often to check for scheduled/delayed actions (seconds)
# Default: 30
QUEUE_SCHEDULED_CHECK_INTERVAL=30

# Queue Maximum Retry Attempts (OPTIONAL)
# How many times to retry failed actions before giving up
# Default: 3
QUEUE_MAX_ATTEMPTS=3

# Queue Retry Backoff Multiplier (OPTIONAL)
# Exponential backoff multiplier for retries (2 = double wait each time)
# Example: 1st retry after 1s, 2nd after 2s, 3rd after 4s
# Default: 2
QUEUE_RETRY_BACKOFF_MULTIPLIER=2

# ================================================================================
# OPTIONAL - pg-boss Configuration
# ================================================================================
# Advanced pg-boss queue manager settings

# pg-boss Worker Concurrency (OPTIONAL)
# Number of jobs to process simultaneously
# Default: 1 (serial processing to avoid race conditions)
PGBOSS_WORKER_CONCURRENCY=1

# pg-boss Maintenance Interval (OPTIONAL)
# How often to run maintenance tasks (minutes)
# Includes: cleanup, archival, index optimization
# Default: 60
PGBOSS_MAINTENANCE_INTERVAL_MINUTES=60

# Archive Completed Jobs (OPTIONAL)
# Whether to move completed jobs to archive table
# Options: true, false
# Default: true
PGBOSS_ARCHIVE_COMPLETED_JOBS=true

# Job Expiration (OPTIONAL)
# How long to keep archived/completed jobs (days)
# Jobs older than this are permanently deleted
# Default: 30
PGBOSS_JOB_EXPIRATION_DAYS=30

# ================================================================================
# OPTIONAL - Action Queue Observability
# ================================================================================
# Logging and monitoring configuration

# Action Queue Debug Mode (OPTIONAL)
# Enable extra verbose logging for troubleshooting
# Options: true, false
# Default: false
ACTION_QUEUE_DEBUG=false

# Action Queue Log Level (OPTIONAL)
# Log verbosity: debug, info, warn, error
# Default: info
ACTION_QUEUE_LOG_LEVEL=info

# Action Queue Metrics Port (OPTIONAL)
# HTTP port for Prometheus metrics endpoint
# Set to 0 to disable metrics
# Default: 3009
ACTION_QUEUE_METRICS_PORT=3009

# ================================================================================
# OPTIONAL - Rate Limiting & Circuit Breaker
# ================================================================================
# API protection and resilience configuration

# Global API Rate Limit (OPTIONAL)
# Maximum API requests per minute (all services combined)
# Default: 100
GLOBAL_API_RATE_LIMIT=100

# Enable Rate Limiting (OPTIONAL)
# Toggle rate limiting on/off
# Options: true, false
# Default: true
ENABLE_RATE_LIMITING=true

# Circuit Breaker Failure Threshold (OPTIONAL)
# Circuit Breaker Configuration (OPTIONAL)
# Maximum consecutive failures before opening circuit (default: 3)
# Must be > 0
CIRCUIT_BREAKER_MAX_FAILURES=3

# Milliseconds before auto-transitioning from OPEN to HALF_OPEN (default: 3600000 = 1 hour)
# Must be > 0
CIRCUIT_BREAKER_PROBE_INTERVAL_MS=3600000

# NTFY Notifications (OPTIONAL)
# URL to send circuit breaker alerts when circuit opens
# Format: https://ntfy.sh/topic-name or similar
NTFY_URL=

# ================================================================================
# OPTIONAL - Recovery Engine Configuration (P7.7.4)
# ================================================================================
# Auto-recovery probe and manual reset mechanisms

# Recovery Probe Interval (OPTIONAL)
# How often to probe OPEN circuits for automatic recovery (milliseconds)
# Transitions OPEN → HALF_OPEN → CLOSED if heartbeat succeeds
# Default: 3600000 (1 hour)
RECOVERY_PROBE_INTERVAL_MS=3600000

# Admin Token (OPTIONAL)
# Bearer token for recovery endpoints (reset, probe, orphaned reclaim)
# Used for POST /recovery/reset/:agentName, POST /recovery/probe, POST /recovery/orphaned/reclaim
# GET /recovery/status/:agentName is public (no token required)
# SECURITY WARNING: Change this in production!
# Default: test-token
ADMIN_TOKEN=test-token

# Action Queue Service URL (OPTIONAL)
# URL for action-queue service used by recovery CLI
# Default: http://localhost:3007
ACTION_QUEUE_URL=http://localhost:3007

# ================================================================================
# OPTIONAL - Docker/Container Settings
# ================================================================================

# Container User (OPTIONAL)
# UID:GID for file permissions (critical for state files)
# Default: 1001:1001
CONTAINER_UID=1001

# Workspace Volume Mount (OPTIONAL)
# Path to workspace directory on host
# Default: ./workspace
WORKSPACE_PATH=./workspace

# ================================================================================
# SUMMARY OF REQUIRED vs OPTIONAL
# ================================================================================
#
# REQUIRED (must be set):
#   - MOLTBOOK_API_KEY
#   - POSTGRES_PASSWORD (change from default in production)
#
# OPTIONAL BUT RECOMMENDED (should configure for full functionality):
#   - VENICE_API_KEY or KIMI_API_KEY (at least one for AI generation)
#   - NTFY_URL + NTFY_API_KEY (for real-time notifications)
#   - ACTION_QUEUE_PORT (if customizing queue service port)
#   - QUEUE_PROCESSING_INTERVAL (to tune responsiveness)
#
# OPTIONAL WITH SENSIBLE DEFAULTS:
#   - All other variables (safe to leave as-is)
#
# DATABASE & QUEUE:
#   - PostgreSQL: Connection variables for Noosphere and action-queue
#   - Noosphere: Built-in 3-layer memory (always enabled, default)
#   - Action Queue: pg-boss job queue for Moltbook actions (always enabled)
#   - Both databases use same PostgreSQL instance
#
# MEMORY SYSTEMS:
#   - Noosphere: Built-in 3-layer memory (always enabled, default)
#   - Mem0: Optional agentic memory service (requires MEM0_API_KEY)
#   - Both can work together (Noosphere primary, Mem0 supplemental)
#
# Notes:
# - If Venice and Kimi keys are both missing, the system falls back to templates
# - If NTFY is not configured, notifications are silently disabled
# - If MEM0_API_KEY is not set, Mem0 features are disabled (Noosphere is primary)
# - Docker Compose service URLs should not need changing in standard setup
# - Workspace permissions (CONTAINER_UID) are critical if rebuilding
# - PostgreSQL and action-queue settings are critical for system operation
# - Change POSTGRES_PASSWORD from default in production environments
#
# For help, see: README.md, AGENTS.md, and docs/ENVIRONMENT_VARIABLES.md
